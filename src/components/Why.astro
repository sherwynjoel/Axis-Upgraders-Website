---
import CircleCheck from '@lucide/astro/icons/circle-check';
import { getContent } from '../utils/content';
const { why } = getContent();
---
<section class="why" id="why-axis">
  <div class="container">
    <div class="why-grid">
      <div 
        class="why-image" 
        data-key="why.image" 
        style={`background-image: linear-gradient(180deg, rgba(15,12,9,0.08), rgba(15,12,9,0.18)), url("${why.image}")`}
        aria-hidden="true"
      ></div>
      <div class="why-copy">
        <p class="eyebrow" data-key="why.eyebrow">{why.eyebrow}</p>
        <h2 data-key="why.title" set:html={why.title.replace(' ', '<br />')} />
        <ul class="why-list">
          {why.items.map((item, index) => (
            <li data-key={`why.items.${index}`}>
              <CircleCheck aria-hidden="true" />
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
