---
import { getContent } from '../utils/content';
const { about } = getContent();
---
<section class="section-light positioning" id="about">
  <div class="container">
    <p class="eyebrow center" data-key="about.eyebrow">{about.eyebrow}</p>
    <h2 data-key="about.title">{about.title}</h2>
    <p data-key="about.content">{about.content}</p>
  </div>
</section>
