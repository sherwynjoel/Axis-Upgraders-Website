---
import Hammer from '@lucide/astro/icons/hammer';
import TrendingUp from '@lucide/astro/icons/trending-up';
import Network from '@lucide/astro/icons/network';
import ClipboardList from '@lucide/astro/icons/clipboard-list';
import Building from '@lucide/astro/icons/building';
import House from '@lucide/astro/icons/house';
import Wrench from '@lucide/astro/icons/wrench';
import HardHat from '@lucide/astro/icons/hard-hat';
import DollarSign from '@lucide/astro/icons/dollar-sign';
import Briefcase from '@lucide/astro/icons/briefcase';
import Target from '@lucide/astro/icons/target';
import Users from '@lucide/astro/icons/users';
import Shield from '@lucide/astro/icons/shield';
import Lightbulb from '@lucide/astro/icons/lightbulb';
import Settings from '@lucide/astro/icons/settings';
import Key from '@lucide/astro/icons/key';
import Calendar from '@lucide/astro/icons/calendar';
import FileText from '@lucide/astro/icons/file-text';
import Wallet from '@lucide/astro/icons/wallet';
import Gauge from '@lucide/astro/icons/gauge';
import Sparkles from '@lucide/astro/icons/sparkles';
import Award from '@lucide/astro/icons/award';
import ChartLine from '@lucide/astro/icons/chart-line';
import ChartNoAxesCombined from '@lucide/astro/icons/chart-no-axes-combined';
import ChevronLeft from '@lucide/astro/icons/chevron-left';
import ChevronRight from '@lucide/astro/icons/chevron-right';
import { getContent } from '../utils/content';

const { services } = getContent();

const iconMap = {
  Hammer, TrendingUp, Network, ClipboardList,
  Building, House, Wrench, HardHat,
  DollarSign, Briefcase, Target, Users,
  Shield, Lightbulb, Settings, Key,
  Calendar, FileText, Wallet, Gauge,
  Sparkles, Award, ChartLine, ChartNoAxesCombined,
};
const iconEntries = Object.entries(iconMap);
---
<section class="services" id="services">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow center" data-key="services.eyebrow">{services.eyebrow}</p>
    </div>
    <div class="carousel-3d">
      <div class="carousel-stage" data-dynamic-list="services.items">

        {services.items.map((item, index) => {
          const Icon = iconMap[item.icon] || Hammer;
          return (
            <article class="service-card c-slide" data-index={index}>
              <div class="card-icon">
                <Icon aria-hidden="true" />
              </div>
              <h3 set:html={item.title.replace(/\\n|\n/g, '<br />')} />
              <p>{item.description}</p>
              <a class="learn" href="#consult">Learn More <span aria-hidden="true">&rarr;</span></a>
            </article>
          );
        })}

      </div>
      <div class="carousel-nav">
        <button class="carousel-btn carousel-prev" aria-label="Previous service">
          <ChevronLeft aria-hidden="true" />
        </button>
        <div class="carousel-dots"></div>
        <button class="carousel-btn carousel-next" aria-label="Next service">
          <ChevronRight aria-hidden="true" />
        </button>
      </div>
      <div class="carousel-progress"><div class="carousel-progress-bar"></div></div>
    </div>

    {/* Hidden registry of every supported icon SVG. The hydration script clones
        the matching entry by data-icon-name when it (re)builds service cards
        from the live JSON. */}
    <template id="service-icons">
      {iconEntries.map(([name, Icon]) => (
        <span data-icon-name={name}><Icon aria-hidden="true" /></span>
      ))}
    </template>
  </div>
</section>

<script>
  import gsap from 'gsap';

  type PosConfig = {
    x: string; scale: number; rotateY: number; opacity: number;
    filter: string; zIndex: number; pointerEvents: string; cursor: string;
    boxShadow: string;
  };

  const CONFIGS: Record<number, PosConfig> = {
    [-2]: { x: '-158%', scale: 0.62, rotateY: 54,  opacity: 0.12, filter: 'blur(3px) brightness(0.38)', zIndex: 1, pointerEvents: 'none',  cursor: 'default', boxShadow: 'none' },
    [-1]: { x: '-70%',  scale: 0.83, rotateY: 33,  opacity: 0.65, filter: 'brightness(0.62)',            zIndex: 2, pointerEvents: 'auto',  cursor: 'pointer', boxShadow: 'none' },
    [0]:  { x: '0%',   scale: 1,    rotateY: 0,   opacity: 1,    filter: 'none',                        zIndex: 3, pointerEvents: 'auto',  cursor: 'default', boxShadow: '0 0 90px rgba(200,162,93,0.26), 0 28px 56px rgba(0,0,0,0.6)' },
    [1]:  { x: '70%',  scale: 0.83, rotateY: -33, opacity: 0.65, filter: 'brightness(0.62)',            zIndex: 2, pointerEvents: 'auto',  cursor: 'pointer', boxShadow: 'none' },
    [2]:  { x: '158%', scale: 0.62, rotateY: -54, opacity: 0.12, filter: 'blur(3px) brightness(0.38)', zIndex: 1, pointerEvents: 'none',  cursor: 'default', boxShadow: 'none' },
  };

  // Track teardown so re-init is clean.
  let teardown: (() => void) | null = null;

  function initServicesCarousel() {
    if (teardown) { teardown(); teardown = null; }

    const stage = document.querySelector('.carousel-stage') as HTMLElement | null;
    if (!stage) return;
    const slides = Array.from(stage.querySelectorAll<HTMLElement>('.c-slide'));
    if (slides.length === 0) return;

    // Clone-replace nav buttons to drop any previously attached listeners.
    document.querySelectorAll<HTMLElement>('.carousel-prev, .carousel-next').forEach(btn => {
      btn.replaceWith(btn.cloneNode(true));
    });
    const prevBtn = document.querySelector('.carousel-prev') as HTMLButtonElement;
    const nextBtn = document.querySelector('.carousel-next') as HTMLButtonElement;
    const dotsContainer = document.querySelector('.carousel-dots') as HTMLElement;
    const progressBar = document.querySelector('.carousel-progress-bar') as HTMLElement;
    const total = slides.length;
    let current = 0;
    let touchStartX = 0;
    let animating = false;
    let autoTimer: ReturnType<typeof setTimeout> | null = null;
    let progressAnim: gsap.core.Tween | null = null;
    const AUTO_DELAY = 3200;

    function applyPos(slide: HTMLElement, pos: number, instant: boolean) {
      const c = CONFIGS[pos];
      if (!c) return;
      slide.style.zIndex = String(c.zIndex);
      slide.style.pointerEvents = c.pointerEvents;
      slide.style.cursor = c.cursor;
      if (instant) {
        gsap.set(slide, { x: c.x, scale: c.scale, rotateY: c.rotateY, opacity: c.opacity, boxShadow: c.boxShadow });
        slide.style.filter = c.filter;
      } else {
        gsap.to(slide, {
          x: c.x, scale: c.scale, rotateY: c.rotateY,
          opacity: c.opacity, boxShadow: c.boxShadow,
          duration: 0.68, ease: 'power3.inOut', overwrite: 'auto',
        });
        gsap.to(slide, { filter: c.filter, duration: 0.68, ease: 'power2.inOut', overwrite: 'auto' });
      }
    }

    function buildDots() {
      dotsContainer.innerHTML = '';
      for (let i = 0; i < total; i++) {
        const dot = document.createElement('button');
        dot.className = 'carousel-dot' + (i === current ? ' active' : '');
        dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        dot.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(dot);
      }
    }

    function updateDots() {
      dotsContainer.querySelectorAll('.carousel-dot').forEach((d, i) => {
        d.classList.toggle('active', i === current);
      });
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current === total - 1;
    }

    function update(instant = false) {
      slides.forEach((slide, i) => {
        const pos = Math.max(-2, Math.min(2, i - current));
        slide.setAttribute('data-pos', String(pos));
        applyPos(slide, pos, instant);
      });
      updateDots();
    }

    function stopAuto() {
      if (autoTimer) { clearTimeout(autoTimer); autoTimer = null; }
      if (progressAnim) { progressAnim.kill(); progressAnim = null; }
      gsap.set(progressBar, { scaleX: 0 });
    }

    function startAuto() {
      stopAuto();
      gsap.set(progressBar, { scaleX: 0, transformOrigin: 'left center' });
      progressAnim = gsap.to(progressBar, { scaleX: 1, duration: AUTO_DELAY / 1000, ease: 'none' });
      autoTimer = setTimeout(() => {
        const next = current < total - 1 ? current + 1 : 0;
        goTo(next);
        startAuto();
      }, AUTO_DELAY);
    }

    function goTo(index: number, restartAuto = false) {
      if (animating) return;
      const next = ((index % total) + total) % total;
      if (next === current) return;
      animating = true;
      current = next;
      update();
      setTimeout(() => { animating = false; }, 700);
      if (restartAuto) startAuto();
    }

    const carousel3d = stage.closest('.carousel-3d') as HTMLElement;
    const onMouseEnter = () => stopAuto();
    const onMouseLeave = () => startAuto();
    carousel3d.addEventListener('mouseenter', onMouseEnter);
    carousel3d.addEventListener('mouseleave', onMouseLeave);

    const onPrev = () => { stopAuto(); goTo(current - 1); startAuto(); };
    const onNext = () => { stopAuto(); goTo(current + 1); startAuto(); };
    prevBtn.addEventListener('click', onPrev);
    nextBtn.addEventListener('click', onNext);

    slides.forEach(slide => {
      slide.addEventListener('click', () => {
        const pos = parseInt(slide.getAttribute('data-pos') || '0');
        if (pos === -1) { stopAuto(); goTo(current - 1); startAuto(); }
        if (pos === 1)  { stopAuto(); goTo(current + 1); startAuto(); }
      });
    });

    const onTouchStart = (e: TouchEvent) => { touchStartX = e.touches[0].clientX; stopAuto(); };
    const onTouchEnd = (e: TouchEvent) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 44) goTo(diff > 0 ? current + 1 : current - 1);
      startAuto();
    };
    stage.addEventListener('touchstart', onTouchStart, { passive: true });
    stage.addEventListener('touchend',   onTouchEnd,   { passive: true });

    const onKeydown = (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft')  { stopAuto(); goTo(current - 1); startAuto(); }
      if (e.key === 'ArrowRight') { stopAuto(); goTo(current + 1); startAuto(); }
    };
    document.addEventListener('keydown', onKeydown);

    update(true);
    buildDots();

    const entrance = gsap.timeline({
      delay: 0.15,
      onComplete: startAuto,
    });
    slides.forEach((slide, i) => {
      const pos = Math.max(-2, Math.min(2, i - current));
      const c = CONFIGS[pos];
      gsap.set(slide, { opacity: 0, y: pos === 0 ? -28 : 18 });
      entrance.to(slide, {
        opacity: c.opacity, y: 0,
        duration: 0.7, ease: 'power3.out',
      }, i === 0 ? 0 : `-=0.52`);
    });

    teardown = () => {
      stopAuto();
      entrance.kill();
      document.removeEventListener('keydown', onKeydown);
      carousel3d.removeEventListener('mouseenter', onMouseEnter);
      carousel3d.removeEventListener('mouseleave', onMouseLeave);
      stage.removeEventListener('touchstart', onTouchStart);
      stage.removeEventListener('touchend',   onTouchEnd);
      // prevBtn / nextBtn listeners die with the clone-replace on next init.
    };
  }

  // Expose so the content-hydration script can re-call after rebuilding cards.
  (window as any).initServicesCarousel = initServicesCarousel;

  initServicesCarousel();
</script>
