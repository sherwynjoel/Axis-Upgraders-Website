---
import Phone from '@lucide/astro/icons/phone';
import Mail from '@lucide/astro/icons/mail';
import Instagram from '@lucide/astro/icons/instagram';
import { getContent } from '../utils/content';
const { footer } = getContent();
---
<footer class="footer" id="contact">
  <div class="container">
    <div class="footer-main">
      <div class="footer-col">
        <div class="footer-brand">
          <img class="brand-mark" src="/logo.png" alt="" />
          <span class="brand-copy">
            <strong>AXIS</strong>
            <span>Upgraders</span>
          </span>
        </div>
        <div class="footer-tagline" data-key="footer.tagline" set:html={footer.tagline.replace(' ', '<br />')} />
        <div class="socials" aria-label="Social links">
          <a class="social" href="https://www.instagram.com/axisupgraders?igsh=MWxkaWt5MW0wb2c3bQ==" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <Instagram aria-hidden="true" />
          </a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-title">Quick Links</div>
        <div class="footer-list">
          <a href="#about">About Us</a>
          <a href="#about">Services</a>
          <a href="#why-axis">Why Axis</a>
          <a href="#process">Process</a>
          <a href="#contact">Contact</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-title">Contact</div>
        <div class="footer-contact">
          <span>
            <Phone aria-hidden="true" />
            <a href={footer.phone_link} data-key="footer.phone">{footer.phone}</a>
          </span>
          <span>
            <Mail aria-hidden="true" />
            <a href={footer.email_link} data-key="footer.email">{footer.email}</a>
          </span>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-title">Service Area</div>
        <div class="footer-area" data-key="footer.service_area" set:html={footer.service_area.replace(' Area', ' Area<br />')} />
      </div>
    </div>

    <div class="footer-bottom">
      <p data-key="footer.copyright">{footer.copyright}</p>
      <p data-key="footer.disclaimer">{footer.disclaimer}</p>
      <p class="powered-by">Powered by <a href="https://thearktech.in/" target="_blank" rel="noopener">The Ark Tech</a></p>
    </div>
  </div>
</footer>
