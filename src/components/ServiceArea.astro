---
import { getContent } from '../utils/content';
const { service_area } = getContent();
---
<section class="service-area">
  <div class="container">
    <div class="area-grid">
      <div class="area-copy">
        <p class="eyebrow" data-key="service_area.eyebrow">{service_area.eyebrow}</p>
        <h2 data-key="service_area.title" set:html={service_area.title.replace(/\\n|\n/g, '<br />')} />
      </div>
      <div class="area-text">
        <p data-key="service_area.content">{service_area.content}</p>
      </div>
      <div 
        class="area-image" 
        data-key="service_area.image" 
        style={`background-image: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.04)), url("${service_area.image}")`}
        aria-hidden="true"
      ></div>
    </div>
  </div>
</section>
