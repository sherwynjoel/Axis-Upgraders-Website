---
import MapPin from '@lucide/astro/icons/map-pin';
import Building2 from '@lucide/astro/icons/building-2';
import Layers from '@lucide/astro/icons/layers';
import BarChart2 from '@lucide/astro/icons/chart-column-increasing';
---
<section class="trust-strip">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-item">
        <MapPin aria-hidden="true" />
        <strong>Serving<br />Greater Toronto Area</strong>
      </div>
      <div class="trust-item">
        <Building2 aria-hidden="true" />
        <strong>Residential &amp;<br />Investment Properties</strong>
      </div>
      <div class="trust-item">
        <Layers aria-hidden="true" />
        <strong>End-to-End<br />Project Oversight</strong>
      </div>
      <div class="trust-item">
        <BarChart2 aria-hidden="true" />
        <strong>Results-Driven<br />Approach</strong>
      </div>
    </div>
  </div>
</section>
