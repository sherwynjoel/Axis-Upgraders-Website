---
import { getContent } from '../utils/content';
const { process } = getContent();
---
<section class="process" id="process">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow center">{process.eyebrow}</p>
      <h2>{process.title}</h2>
    </div>
    <div class="process-grid">
      {process.steps.map((step, index) => (
        <article class="step">
          <div class="step-number">{index + 1}</div>
          <h3 data-key={`process.steps.${index}.title`} set:html={step.title.replace(/\\n|\n/g, '<br />')} />
          <p data-key={`process.steps.${index}.description`}>{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
