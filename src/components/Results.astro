---
import TrendingUp from '@lucide/astro/icons/trending-up';
import Home from '@lucide/astro/icons/house';
import Zap from '@lucide/astro/icons/zap';
import ShieldCheck from '@lucide/astro/icons/shield-check';
import { getContent } from '../utils/content';

const { results } = getContent();
const iconMap = [TrendingUp, Home, Zap, ShieldCheck];
---
<section class="results">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow center" data-key="results.eyebrow">{results.eyebrow}</p>
    </div>
    <div class="results-grid">
      {results.items.map((item, index) => {
        const Icon = iconMap[index] || TrendingUp;
        return (
          <div class="result-item">
            <Icon aria-hidden="true" />
            <strong data-key={`results.items.${index}`} set:html={item.replace(' ', '<br />')} />
          </div>
        );
      })}
    </div>
  </div>
</section>
