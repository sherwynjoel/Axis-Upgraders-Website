---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Why from '../components/Why.astro';
import Results from '../components/Results.astro';
import Process from '../components/Process.astro';
import ServiceArea from '../components/ServiceArea.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { getContent } from '../utils/content';

const content = getContent();
---

<Layout title="Visual Admin - Axis Upgraders">
  <div id="initial-data" data-json={JSON.stringify(content)} class="hidden"></div>
  <div class="admin-overlay">
    <div class="admin-toolbar">
      <div class="admin-logo">AXIS EDITOR</div>
      <div class="admin-status" id="admin-status">Editing Mode Active</div>
      <div class="admin-actions">
        <button id="save-btn" class="save-btn">Save Changes</button>
        <button id="manual-btn" class="manual-btn">Manual Save</button>
        <a href="/" class="exit-btn">Exit</a>
      </div>
    </div>
  </div>

  <main class="site editing-enabled">
    <Hero />
    <TrustStrip />
    <div class="viewport-block">
      <About />
      <Services />
    </div>
    <div class="viewport-block">
      <Why />
      <Results />
    </div>
    <div class="process-wrapper">
        <Process />
    </div>
    <ServiceArea />
    <CTA />
    <Footer />
  </main>
</Layout>

<style is:global>
  /* Admin Styles */
  .admin-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 9999;
    pointer-events: none;
  }
  .admin-toolbar {
    pointer-events: auto;
    background: rgba(15, 17, 21, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #c8a25d;
    padding: 12px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }
  .admin-logo {
    color: #c8a25d;
    font-weight: 800;
    letter-spacing: 1px;
    font-size: 0.9rem;
  }
  .admin-status {
    font-size: 0.8rem;
    color: #4ade80;
    font-weight: 500;
  }
  .admin-actions {
    display: flex; gap: 12px;
  }
  .save-btn {
    background: #c8a25d;
    color: #000;
    border: none;
    padding: 8px 20px;
    border-radius: 4px;
    font-weight: 700;
    cursor: pointer;
    font-size: 0.85rem;
  }
  .manual-btn {
    background: #333;
    color: #fff;
    border: 1px solid #c8a25d;
    padding: 8px 16px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.85rem;
  }
  .exit-btn {
    background: transparent;
    color: #fff;
    border: 1px solid #444;
    padding: 8px 16px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.85rem;
  }

  [data-key] {
    outline: 1px dashed rgba(200, 162, 93, 0.3);
    outline-offset: 4px;
    cursor: text;
  }
  [data-key]:hover { outline: 1px solid #c8a25d; background: rgba(200, 162, 93, 0.05); }

  .hidden { display: none; }

  .toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    padding: 12px 24px;
    border-radius: 4px;
    color: white;
    font-weight: 600;
    z-index: 10000;
    animation: slideIn 0.3s ease-out;
  }
  @keyframes slideIn {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }
</style>

<script>
  // Enable Editing
  document.querySelectorAll('[data-key]').forEach(el => {
    if (el.tagName !== 'IMG') {
      (el as HTMLElement).contentEditable = 'true';
    }
  });

  // Handle Image Clicks
  document.querySelectorAll('[data-key*="image"]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      let currentSrc = (el.tagName === 'IMG') ? (el as HTMLImageElement).src : window.getComputedStyle(el).backgroundImage.replace(/url\(['"]?(.*?)['"]?\)/i, '$1');
      const newSrc = prompt('Enter new image URL:', currentSrc);
      if (newSrc && newSrc !== currentSrc) {
        if (el.tagName === 'IMG') (el as HTMLImageElement).src = newSrc;
        else (el as HTMLElement).style.backgroundImage = `url("${newSrc}")`;
        showToast('Local preview updated.', '#c8a25d');
      }
    });
  });

  // Data Collector
  function collectData() {
    const dataEl = document.getElementById('initial-data');
    const data = JSON.parse(dataEl?.getAttribute('data-json') || '{}');

    document.querySelectorAll('[data-key]').forEach(el => {
      const key = el.getAttribute('data-key');
      if (!key) return;

      let value;
      if (el.tagName === 'IMG') {
        value = (el as HTMLImageElement).getAttribute('src');
      } else if (key.includes('image')) {
        const bg = (el as HTMLElement).style.backgroundImage || window.getComputedStyle(el).backgroundImage;
        value = bg.replace(/url\(['"]?(.*?)['"]?\)/i, '$1');
      } else {
        value = (el as HTMLElement).innerText;
      }

      const keys = key.split('.');
      let temp = data;
      for (let i = 0; i < keys.length; i++) {
        const k = keys[i];
        if (i === keys.length - 1) temp[k] = value;
        else { temp[k] = temp[k] || {}; temp = temp[k]; }
      }
    });
    return data;
  }

  // Handle Save
  const saveBtn = document.getElementById('save-btn');
  saveBtn?.addEventListener('click', async () => {
    saveBtn.innerText = 'Saving...';
    const data = collectData();
    
    try {
      const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
      
      if (isLocal) {
        // Automatic Local Saving via the dedicated server (node save-server.mjs)
        const response = await fetch('http://localhost:3001/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        const resData = await response.json();
        if (response.ok && resData.success) {
          showToast('Changes saved automatically!', '#4ade80');
        } else {
          throw new Error('Local saver not running. Run "node save-server.mjs"');
        }
      } else {
        // Automatic cPanel Saving via PHP
        const response = await fetch('/save-content.php', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        const resData = await response.json();
        if (response.ok && resData.success) {
          showToast('Changes saved to server!', '#4ade80');
        } else {
          throw new Error(resData.error || 'Server error');
        }
      }
    } catch (err) {
      showToast('Auto-save failed. Use Manual Save.', '#f87171');
      console.error('Save Error:', err);
    } finally {
      saveBtn.innerText = 'Save Changes';
    }
  });

  // Manual Save (Fallback)
  document.getElementById('manual-btn')?.addEventListener('click', () => {
    const data = collectData();
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'site-content.json';
    a.click();
    alert('AUTOSAVE FAILED.\n\nI have downloaded a file called "site-content.json".\n\nPlease copy this file and replace the one in your "public" folder to save your changes manually.');
  });

  function showToast(msg, color) {
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.style.backgroundColor = color;
    toast.innerText = msg;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
  }
</script>
